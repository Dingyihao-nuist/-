{
  "permissions": {
    "allow": [
      "Bash(cd frontend && npm *)",
      "Bash(cd backend && *)",
      "Bash(mkdir *)",
      "Bash(xcopy *)",
      "Bash(copy *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git *)",
      "Bash(bash .claude/hooks/*)",
      "Bash(cat .claude/artifacts/*)",
      "Bash(date *)",
      "Bash(sleep *)",
      "Bash(for *)",
      "Bash(echo *)",
      "Bash(test *)",
      "Bash(chmod *)",
      "Bash(python3 *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/commit-gate.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
